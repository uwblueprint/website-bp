{
  "name": "website-bp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "yarn lint:prettier && yarn lint:eslint && yarn lint:tsc",
    "lint:prettier": "prettier --check '**/*.{js,jsx,ts,tsx}'",
    "lint:eslint": "eslint '**/*.{js,jsx,ts,tsx}' --cache --format stylish",
    "lint:tsc": "tsc --noemit",
    "fix": "yarn fix:eslint && yarn fix:prettier",
    "fix:prettier": "prettier --write '**/*.{js,jsx,ts,tsx}'",
    "fix:eslint": "eslint '**/*.{js,jsx,ts,tsx}' --format stylish --fix",
    "prettier": "prettier --write '**/*.{js,jsx,ts,tsx}'"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react-csv": "^1.1.3",
    "@types/uuid": "^8.3.4",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.7",
    "eslint-config-next": "^15.5.14",
    "firebase": "^9.12.1",
    "formik": "^2.2.9",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "^15.5.14",
    "react": "^18.3.1",
    "react-csv": "^2.2.2",
    "react-dom": "^18.3.1",
    "react-feather": "^2.0.10",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@netlify/plugin-nextjs": "^5.15.9",
    "@types/node": "18.11.9",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^5",
    "@typescript-eslint/parser": "^5",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^7.0.0",
    "eslint-plugin-prettier": "^3.2.0",
    "husky": "^8.0.1",
    "lint-staged": "^10.5.3",
    "postcss": "^8.4.17",
    "prettier": "^2.5.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --cache --fix",
    "*.{ts,tsx,md}": "prettier --write"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
